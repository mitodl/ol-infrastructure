# mitxonline Tiltfile
# Builds the mitxonline Django app (granian) and deploys it to the mitxonline namespace.
# When the sibling mitxonline repo is not checked out, Tilt uses the prebuilt
# DockerHub image (mitodl/mitxonline-app:latest) without attempting a local build.

load("../../tiltlib.star", "k8s_yaml_with_domain")

workspace_root = os.environ.get("MITOL_WORKSPACE_ROOT", config.main_dir + "/..")
APP_DIR = os.path.join(workspace_root, "mitxonline")
IMAGE = 'mitodl/mitxonline-app'
NAMESPACE = 'mitxonline'
DEPLOY_NAME = 'mitxonline-webapp'

if os.path.exists(os.path.join(APP_DIR, '.git')):
    # Build the `production` target: it's the only one that bakes in the
    # compiled webpack frontend (`COPY --from=node`), which checkout needs since
    # that flow still runs through mitxonline.mit.dev. `production` has no dev
    # deps, so DEBUG must be False (see app-env.yaml) or the app crashes
    # importing debug_toolbar. No Python hot-reload yet (granian has no
    # --reload); synced source changes need a rebuild/restart.
    docker_build(
        IMAGE,
        context=APP_DIR,
        target='production',
        dockerfile=APP_DIR + '/Dockerfile',
        live_update=[
            sync(APP_DIR + '/mitxonline', '/src/mitxonline'),
            sync(APP_DIR + '/main', '/src/main'),
            # Reinstall deps on pyproject.toml/uv.lock change (uv, not pip;
            # --no-dev matches the production image).
            run(
                'cd /src && uv sync --frozen --no-dev',
                trigger=[APP_DIR + '/pyproject.toml', APP_DIR + '/uv.lock'],
            ),
        ],
    )

k8s_yaml_with_domain([
    'configmaps/app-env.yaml',
    'configmaps/nginx.yaml',
    'secrets.yaml',
    'deployment.yaml',
    'apisix-routes.yaml',
])

k8s_resource(
    DEPLOY_NAME,
    port_forwards=['8010:8010'],
    labels=['mitxonline'],
    resource_deps=['local-infra-apps'],
)

k8s_resource('mitxonline-celery', labels=['mitxonline'], resource_deps=['local-infra-apps'])
k8s_resource('mitxonline-celery-beat', labels=['mitxonline'], resource_deps=['local-infra-apps'])
