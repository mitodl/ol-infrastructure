# learn-ai Tiltfile
# Builds the learn-ai Django/ASGI app and deploys it to the learn-ai namespace.

load('ext://restart_process', 'docker_build_with_restart')

APP_DIR = os.path.abspath('../../../learn-ai')
IMAGE = 'learnai-app'
NAMESPACE = 'learn-ai'
DEPLOY_NAME = 'learnai-webapp'

docker_build(
    IMAGE,
    context=APP_DIR,
    dockerfile=APP_DIR + '/Dockerfile',
    live_update=[
        sync(APP_DIR + '/main', '/src/main'),
        run(
            'cd /src && pip install -r requirements.txt',
            trigger=[APP_DIR + '/requirements.txt'],
        ),
    ],
)

k8s_yaml([
    'configmaps/app-env.yaml',
    'configmaps/nginx.yaml',
    'secrets.yaml',
    'deployment.yaml',
    'apisix-routes.yaml',
])

k8s_resource(
    DEPLOY_NAME,
    port_forwards=['8000:8000'],
    labels=['learn-ai'],
)

k8s_resource('learnai-celery-default', labels=['learn-ai'])
k8s_resource('learnai-celery-edx-content', labels=['learn-ai'])
k8s_resource('learnai-celery-beat', labels=['learn-ai'])
