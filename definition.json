{
  "jobs": [
    {
      "max_in_flight": 1.0,
      "name": "deploy-ol-infrastructure-micromasters-application-applications.micromasters.ci",
      "on_abort": {
        "params": {
          "alert_type": "aborted",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.CI aborted",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.ci encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_error": {
        "params": {
          "alert_type": "errored",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.CI errored",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.ci encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_failure": {
        "params": {
          "alert_type": "failed",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.CI failed",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.ci encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "plan": [
        {
          "passed": [
            "build-micromasters-image-from-main"
          ],
          "trigger": true,
          "get": "micromasters-app-ci-ecr-image",
          "params": {
            "skip_download": true
          }
        },
        {
          "load_var": "image_digest",
          "reveal": true,
          "file": "micromasters-app-ci-ecr-image/digest"
        },
        {
          "trigger": true,
          "get": "ol-infra-micromasters"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "amazon/aws-cli",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "path": "ol-infra-micromasters/pipelines/infrastructure/scripts/generate_aws_config_from_instance_profile.sh"
            },
            "inputs": [
              {
                "name": "ol-infra-micromasters"
              }
            ],
            "platform": "linux",
            "outputs": [
              {
                "name": "aws_creds"
              }
            ]
          },
          "task": "set-aws-creds"
        },
        {
          "params": {
            "env_os": {
              "AWS_DEFAULT_REGION": "us-east-1",
              "PYTHONPATH": "/usr/lib/:/tmp/build/put/ol-infra-micromasters/src/",
              "GITHUB_TOKEN": "((github.public_repo_access_token))",
              "MICROMASTERS_DOCKER_SHA": "((.:image_digest))"
            },
            "stack_name": "applications.micromasters.CI",
            "env_vars_from_files": {}
          },
          "put": "pulumi-ol-infrastructure-micromasters-application",
          "inputs": "all",
          "no_get": true
        }
      ]
    },
    {
      "max_in_flight": 1.0,
      "name": "deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa",
      "on_abort": {
        "params": {
          "alert_type": "aborted",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.QA aborted",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_error": {
        "params": {
          "alert_type": "errored",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.QA errored",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_failure": {
        "params": {
          "alert_type": "failed",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.QA failed",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "plan": [
        {
          "passed": [
            "build-micromasters-release-image"
          ],
          "trigger": true,
          "get": "micromasters-app-release-ecr-image",
          "params": {
            "skip_download": true
          }
        },
        {
          "load_var": "image_tag",
          "reveal": true,
          "file": "micromasters-app-release-ecr-image/tag"
        },
        {
          "passed": [
            "build-micromasters-release-image"
          ],
          "trigger": false,
          "get": "micromasters-release"
        },
        {
          "params": {
            "action": "start",
            "ref": "((.:image_tag))"
          },
          "put": "micromasters-deployment-rc"
        },
        {
          "trigger": true,
          "get": "ol-infra-micromasters"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "amazon/aws-cli",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "path": "ol-infra-micromasters/pipelines/infrastructure/scripts/generate_aws_config_from_instance_profile.sh"
            },
            "inputs": [
              {
                "name": "ol-infra-micromasters"
              }
            ],
            "platform": "linux",
            "outputs": [
              {
                "name": "aws_creds"
              }
            ]
          },
          "task": "set-aws-creds"
        },
        {
          "params": {
            "env_os": {
              "AWS_DEFAULT_REGION": "us-east-1",
              "PYTHONPATH": "/usr/lib/:/tmp/build/put/ol-infra-micromasters/src/",
              "GITHUB_TOKEN": "((github.public_repo_access_token))",
              "MICROMASTERS_DOCKER_TAG": "((.:image_tag))"
            },
            "stack_name": "applications.micromasters.QA",
            "env_vars_from_files": {}
          },
          "put": "pulumi-ol-infrastructure-micromasters-application",
          "inputs": "all",
          "no_get": true
        },
        {
          "params": {
            "body_file": "micromasters-release/checklist.md",
            "labels": [
              "release"
            ]
          },
          "put": "micromasters-release-issue"
        },
        {
          "params": {
            "action": "finish",
            "deployment_file": "micromasters-deployment-rc/deployment.json",
            "state": "success"
          },
          "put": "micromasters-deployment-rc"
        }
      ]
    },
    {
      "max_in_flight": 1.0,
      "name": "deploy-ol-infrastructure-micromasters-application-applications.micromasters.production",
      "on_abort": {
        "params": {
          "alert_type": "aborted",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.Production aborted",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.production encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_error": {
        "params": {
          "alert_type": "errored",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.Production errored",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.production encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "on_failure": {
        "params": {
          "alert_type": "failed",
          "message": "Pulumi ol-infrastructure-micromasters-application applications.micromasters.Production failed",
          "text": "Pulumi job deploy-ol-infrastructure-micromasters-application-applications.micromasters.production encountered a problem. Check the pipeline for details."
        },
        "put": "slack-alert-ol-infrastructure-micromasters-application"
      },
      "plan": [
        {
          "passed": [
            "deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa"
          ],
          "trigger": false,
          "get": "micromasters-app-release-ecr-image",
          "params": {
            "skip_download": true
          }
        },
        {
          "load_var": "image_tag",
          "reveal": true,
          "file": "micromasters-app-release-ecr-image/tag"
        },
        {
          "trigger": true,
          "get": "micromasters-release-gate"
        },
        {
          "params": {
            "action": "start",
            "ref": "((.:image_tag))"
          },
          "put": "micromasters-deployment-production"
        },
        {
          "passed": [
            "deploy-ol-infrastructure-micromasters-application-applications.micromasters.qa"
          ],
          "trigger": false,
          "get": "ol-infra-micromasters"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "amazon/aws-cli",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "path": "ol-infra-micromasters/pipelines/infrastructure/scripts/generate_aws_config_from_instance_profile.sh"
            },
            "inputs": [
              {
                "name": "ol-infra-micromasters"
              }
            ],
            "platform": "linux",
            "outputs": [
              {
                "name": "aws_creds"
              }
            ]
          },
          "task": "set-aws-creds"
        },
        {
          "params": {
            "env_os": {
              "AWS_DEFAULT_REGION": "us-east-1",
              "PYTHONPATH": "/usr/lib/:/tmp/build/put/ol-infra-micromasters/src/",
              "GITHUB_TOKEN": "((github.public_repo_access_token))",
              "MICROMASTERS_DOCKER_TAG": "((.:image_tag))"
            },
            "stack_name": "applications.micromasters.Production",
            "env_vars_from_files": {}
          },
          "put": "pulumi-ol-infrastructure-micromasters-application",
          "inputs": "all",
          "no_get": true
        },
        {
          "params": {
            "action": "finish",
            "deployment_file": "micromasters-deployment-production/deployment.json",
            "state": "success"
          },
          "put": "micromasters-deployment-production"
        }
      ]
    },
    {
      "build_log_retention": {
        "builds": 10.0
      },
      "name": "build-micromasters-image-from-main",
      "plan": [
        {
          "trigger": true,
          "get": "micromasters-master"
        },
        {
          "load_var": "git_ref",
          "reveal": true,
          "file": "micromasters-master/.git/ref"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "concourse/oci-build-task"
              },
              "type": "registry-image"
            },
            "caches": [
              {
                "path": "cache"
              }
            ],
            "run": {
              "args": [],
              "path": "build"
            },
            "inputs": [
              {
                "name": "micromasters-master"
              }
            ],
            "platform": "linux",
            "params": {
              "CONTEXT": "micromasters-master",
              "DOCKERFILE": "micromasters-master/./Dockerfile",
              "BUILD_ARG_GIT_REF": "((.:git_ref))",
              "TARGET": "production"
            },
            "outputs": [
              {
                "name": "image"
              }
            ]
          },
          "task": "build-container-image",
          "privileged": true
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "amazon/aws-cli",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "args": [
                "-exc",
                "aws ecr describe-repositories --repository-names ${REPO_NAME} || aws ecr create-repository --repository-name ${REPO_NAME}"
              ],
              "path": "sh"
            },
            "platform": "linux",
            "params": {
              "REPO_NAME": "mitodl/micromasters-app",
              "AWS_PAGER": "cat"
            }
          },
          "task": "ensure-ecr-repository"
        },
        {
          "params": {
            "image": "image/image.tar",
            "additional_tags": "./micromasters-master/.git/short_ref"
          },
          "put": "micromasters-app-ci-image"
        },
        {
          "params": {
            "image": "image/image.tar",
            "additional_tags": "./micromasters-master/.git/short_ref"
          },
          "put": "micromasters-app-ci-ecr-image"
        }
      ]
    },
    {
      "build_log_retention": {
        "builds": 10.0
      },
      "name": "build-micromasters-release-image",
      "plan": [
        {
          "trigger": true,
          "get": "micromasters-release"
        },
        {
          "trigger": false,
          "get": "micromasters-master"
        },
        {
          "load_var": "release_version",
          "reveal": true,
          "file": "micromasters-release/version"
        },
        {
          "load_var": "git_ref",
          "reveal": true,
          "file": "micromasters-master/.git/ref"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "ghcr.io/mitodl/ol-concourse-task",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "args": [
                "-ec",
                "VERSION=$(cat micromasters-release/version)\ngit -C micromasters-master config user.email odl-devops@mit.edu\ngit -C micromasters-master config user.name CI\ncd micromasters-master\nbumpver update --set-version \"$VERSION\" --no-commit --no-fetch"
              ],
              "path": "bash"
            },
            "inputs": [
              {
                "name": "micromasters-release"
              },
              {
                "name": "micromasters-master"
              }
            ],
            "platform": "linux",
            "outputs": [
              {
                "name": "micromasters-master"
              }
            ]
          },
          "task": "bump-version",
          "privileged": false
        },
        {
          "params": {
            "action": "create",
            "repo_dir": "micromasters-master",
            "version_file": "micromasters-release/version"
          },
          "put": "micromasters-release"
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "concourse/oci-build-task"
              },
              "type": "registry-image"
            },
            "caches": [
              {
                "path": "cache"
              }
            ],
            "run": {
              "args": [],
              "path": "build"
            },
            "inputs": [
              {
                "name": "micromasters-master"
              }
            ],
            "platform": "linux",
            "params": {
              "CONTEXT": "micromasters-master",
              "DOCKERFILE": "micromasters-master/./Dockerfile",
              "BUILD_ARG_GIT_REF": "((.:git_ref))",
              "BUILD_ARG_RELEASE_VERSION": "((.:release_version))",
              "TARGET": "production"
            },
            "outputs": [
              {
                "name": "image"
              }
            ]
          },
          "task": "build-container-image",
          "privileged": true
        },
        {
          "config": {
            "image_resource": {
              "source": {
                "repository": "amazon/aws-cli",
                "tag": "latest"
              },
              "type": "registry-image"
            },
            "run": {
              "args": [
                "-exc",
                "aws ecr describe-repositories --repository-names ${REPO_NAME} || aws ecr create-repository --repository-name ${REPO_NAME}"
              ],
              "path": "sh"
            },
            "platform": "linux",
            "params": {
              "REPO_NAME": "mitodl/micromasters-app",
              "AWS_PAGER": "cat"
            }
          },
          "task": "ensure-ecr-repository"
        },
        {
          "params": {
            "image": "image/image.tar",
            "additional_tags": "./micromasters-master/.git/short_ref",
            "version": "((.:release_version))",
            "bump_aliases": true
          },
          "put": "micromasters-app-release-image"
        },
        {
          "params": {
            "image": "image/image.tar",
            "additional_tags": "./micromasters-master/.git/short_ref",
            "version": "((.:release_version))",
            "bump_aliases": true
          },
          "put": "micromasters-app-release-ecr-image"
        }
      ]
    }
  ],
  "resource_types": [
    {
      "source": {
        "repository": "mitodl/concourse-pulumi-resource-provisioner",
        "tag": "latest"
      },
      "type": "registry-image",
      "name": "pulumi-provisioner"
    },
    {
      "source": {
        "repository": "arbourd/concourse-slack-alert-resource",
        "tag": "v0.15.0"
      },
      "type": "registry-image",
      "name": "slack-notification"
    },
    {
      "source": {
        "repository": "mitodl/ol-concourse-github-issues",
        "tag": "latest"
      },
      "type": "registry-image",
      "name": "github-issues"
    },
    {
      "source": {
        "repository": "mitodl/concourse-release-resource",
        "tag": "latest"
      },
      "type": "registry-image",
      "name": "release"
    },
    {
      "source": {
        "repository": "mitodl/concourse-github-deployments-resource",
        "tag": "latest"
      },
      "type": "registry-image",
      "name": "github-deployments"
    }
  ],
  "resources": [
    {
      "name": "ol-infra-micromasters",
      "source": {
        "uri": "https://github.com/mitodl/ol-infrastructure",
        "branch": "main",
        "paths": [
          "src/ol_infrastructure/applications/micromasters",
          "src/ol_infrastructure/lib",
          "src/ol_infrastructure/components",
          "pipelines/infrastructure/scripts",
          "src/bridge/secrets"
        ],
        "fetch_tags": false
      },
      "check_every": "60s",
      "icon": "git",
      "type": "git"
    },
    {
      "name": "pulumi-ol-infrastructure-micromasters-application",
      "source": {
        "env_pulumi": {
          "AWS_SHARED_CREDENTIALS_FILE": "aws_creds/credentials"
        },
        "action": "update",
        "project_name": "ol-infrastructure-micromasters-application",
        "source_dir": "ol-infra-micromasters/src/ol_infrastructure/applications/micromasters"
      },
      "icon": "cloud-braces",
      "type": "pulumi-provisioner"
    },
    {
      "name": "micromasters-app-ci-ecr-image",
      "source": {
        "repository": "mitodl/micromasters-app",
        "tag": "latest",
        "aws_region": "us-east-1"
      },
      "check_every": "never",
      "type": "registry-image"
    },
    {
      "name": "micromasters-app-release-ecr-image",
      "source": {
        "repository": "mitodl/micromasters-app",
        "tag": null,
        "tag_regex": "[0-9]+\\.[0-9]+\\.[0-9]+",
        "created_at_sort": true,
        "aws_region": "us-east-1"
      },
      "check_every": "never",
      "type": "registry-image"
    },
    {
      "name": "micromasters-app-ci-image",
      "source": {
        "repository": "mitodl/micromasters-app",
        "tag": "latest",
        "username": "((dockerhub.username))",
        "password": "((dockerhub.password))"
      },
      "check_every": "never",
      "type": "registry-image"
    },
    {
      "name": "micromasters-app-release-image",
      "source": {
        "repository": "mitodl/micromasters-app",
        "tag": null,
        "username": "((dockerhub.username))",
        "password": "((dockerhub.password))",
        "tag_regex": "[0-9]+\\.[0-9]+\\.[0-9]+",
        "created_at_sort": true
      },
      "check_every": "never",
      "type": "registry-image"
    },
    {
      "name": "slack-alert-ol-infrastructure-micromasters-application",
      "source": {
        "url": "((eks.slack_url))",
        "disabled": false
      },
      "type": "slack-notification"
    },
    {
      "name": "micromasters-master",
      "source": {
        "uri": "https://github.com/mitodl/micromasters",
        "branch": "master",
        "fetch_tags": false
      },
      "check_every": "60s",
      "icon": "git",
      "type": "git"
    },
    {
      "name": "micromasters-release",
      "source": {
        "uri": "https://github.com/mitodl/micromasters",
        "branch": "main",
        "git_user_name": "Concourse CI",
        "git_user_email": "concourse@example.com",
        "changelog_file": "CHANGELOG.md",
        "changelog_dir": "releases",
        "access_token": "((github.access_token))",
        "repository": "mitodl/micromasters"
      },
      "check_every": "never",
      "icon": "tag",
      "type": "release"
    },
    {
      "name": "micromasters-release-gate",
      "source": {
        "auth_method": "token",
        "issue_prefix": "Release micromasters",
        "issue_state": "closed",
        "issue_title_template": "Release micromasters",
        "repository": "mitodl/micromasters",
        "skip_if_labeled": [
          "abandoned"
        ],
        "access_token": "((github.issues_resource_access_token))"
      },
      "expose_build_created_by": true,
      "check_every": "60m",
      "icon": "github",
      "type": "github-issues"
    },
    {
      "name": "micromasters-release-issue",
      "source": {
        "auth_method": "token",
        "issue_prefix": "Release micromasters",
        "issue_state": "open",
        "issue_title_template": "Release micromasters",
        "labels": [
          "release"
        ],
        "repository": "mitodl/micromasters",
        "access_token": "((github.issues_resource_access_token))"
      },
      "expose_build_created_by": true,
      "check_every": "60m",
      "icon": "github",
      "type": "github-issues"
    },
    {
      "name": "micromasters-deployment-rc",
      "source": {
        "repository": "mitodl/micromasters",
        "environment": "RC",
        "access_token": "((github.access_token))"
      },
      "check_every": "never",
      "icon": "rocket-launch",
      "type": "github-deployments"
    },
    {
      "name": "micromasters-deployment-production",
      "source": {
        "repository": "mitodl/micromasters",
        "environment": "Production",
        "access_token": "((github.access_token))"
      },
      "check_every": "never",
      "icon": "rocket-launch",
      "type": "github-deployments"
    }
  ]
}